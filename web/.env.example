# Clerk Authentication
# Create a Clerk app at https://clerk.com and get your keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Neon PostgreSQL Database
# Create a project at https://neon.tech and get the connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Firebase Admin SDK
# Option 1: JSON string (for production/Vercel)
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"..."}'
# Option 2: File path (for local development)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Gemini API (optional - only needed for video analysis feature)
GEMINI_API_KEY=your-gemini-api-key

# GCS Bucket Name (default: fazm-session-recordings)
# GCS_BUCKET_NAME=fazm-session-recordings
